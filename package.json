{
  "name": "@anthropic-ai/latam-data-protection-mcp",
  "version": "0.1.0",
  "description": "LATAM data protection laws MCP — LGPD, LPDP, Law 1581, and privacy frameworks across 7 Latin American jurisdictions",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "latam-data-protection-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "data/database.db"
  ],
  "scripts": {
    "build": "tsc",
    "build:db": "tsx scripts/build-db.ts",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "ingest": "tsx scripts/ingest.ts",
    "check-updates": "tsx scripts/check-updates.ts",
    "lint": "tsc --noEmit",
    "validate": "npm run lint && npm test"
  },
  "dependencies": {
    "@ansvar/mcp-sqlite": "^1.0.0",
    "@modelcontextprotocol/sdk": "^1.12.1"
  },
  "devDependencies": {
    "@vercel/node": "^5.6.6",
    "@types/node": "^22.15.29",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "@vitest/coverage-v8": "^3.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ansvar-Systems/latam-data-protection-mcp.git"
  },
  "author": "Ansvar Systems AB <hello@ansvar.ai>",
  "license": "Apache-2.0",
  "keywords": [
    "mcp",
    "data-protection",
    "privacy",
    "lgpd",
    "latam",
    "compliance"
  ],
  "publishConfig": {
    "access": "public"
  }
}
